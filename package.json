{
  "name": "my-ecommerce-app",
  "version": "1.0.0",
  "private": true,
  "author": "Charles Stover <with-router@charlesstover.com>",
  "description": "E-commerce mobile app with React Native, Expo, GraphQL, MongoDB, and Plop",
  "homepage": "https://github.com/CharlesStover/with-router#readme",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
