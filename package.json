    "express": "^4.21.2",
    "graphql": "^16.10.0",
    "mongoose": "^7.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.7",
    "react-native-gesture-handler": "^2.24.0",
